rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if document belongs to caller
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // QR Codes Collection
    match /qr_codes/{qrId} {
      // Anyone can read a QR Code document (since they are scanned publicly)
      allow read: if true;
      
      // Only the owner can create, update, or delete
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // QR Links (for multi-link pages)
    match /qr_links/{linkId} {
      // Anyone can read the links associated with a QR to render the landing page
      allow read: if true;
      
      // Writing requires auth. In a full production system, we would validate 
      // if the request.auth.uid matches the user_id of the parent qr_code document.
      allow write: if isAuthenticated();
    }

    // QR Scans (Analytics tracking)
    match /qr_scans/{scanId} {
      // The public scan engine needs to write a record anonymously
      allow create: if true;
      
      // Only authenticated users can read. 
      // Production scale would require matching the parent QR's user_id.
      allow read: if isAuthenticated();
      
      allow update, delete: if false; // Scans shouldn't be altered
    }

    // AI Campaigns
    match /campaigns/{campaignId} {
       allow read, write: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }
  }
}
