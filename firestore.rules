rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users — only the account owner can read/write/delete their own doc
    match /users/{userId} {
      allow read, write, delete: if isOwner(userId);
    }

    // QR Codes — publicly readable (needed for scanning), owner-only writes/deletes
    match /qr_codes/{qrId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // QR Links — publicly readable (for smart landing pages), owner-only writes/deletes
    match /qr_links/{linkId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // QR Scans — publicly writable (scan engine logs anonymously), 
    // owner can read & delete their own (for account deletion cleanup)
    match /qr_scans/{scanId} {
      allow create: if true;
      allow read, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow update: if false;
    }

    // Campaigns — private to owner
    match /campaigns/{campaignId} {
      allow read, write, delete: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }
  }
}
